# ============================================================
# REQUIRED ENVIRONMENT VARIABLES
# Copy this file to .env.local for local development
# Set these same variables in Railway for production
# ============================================================

# PostgreSQL connection string
# Local example: postgresql://user:password@localhost:5432/parents_app
# Railway: copy the DATABASE_URL from your Railway PostgreSQL service
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE"

# Next.js public URL (used for absolute URLs in production)
# Railway sets this automatically, but you can override it:
# NEXTAUTH_URL="https://your-app.up.railway.app"

# ============================================================
# OPTIONAL — add these when you're ready to expand
# ============================================================

# Google Calendar OAuth (for future calendar integration)
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""
# GOOGLE_REDIRECT_URI=""

# Cloudinary (for future image upload feature)
# CLOUDINARY_CLOUD_NAME=""
# CLOUDINARY_API_KEY=""
# CLOUDINARY_API_SECRET=""

# Supabase Storage (alternative to Cloudinary)
# NEXT_PUBLIC_SUPABASE_URL=""
# NEXT_PUBLIC_SUPABASE_ANON_KEY=""
